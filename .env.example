# Copy to .env — Formspree form ID from https://formspree.io (public, safe in client bundle)
PUBLIC_FORMSPREE_ID=your_form_id_here

# Optional: your live site URL for canonical/OG (also set `site` in astro.config.mjs)
# PUBLIC_SITE_URL=https://yourdomain.com

# Optional: Cal.com or Calendly booking link for iframe/button on /book
PUBLIC_BOOKING_URL=https://cal.com/yourusername
