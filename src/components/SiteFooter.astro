---
const year = new Date().getFullYear();
---

<footer class="border-top border-brand bg-brand-surface mt-5 py-5">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-6">
        <p class="fw-bold mb-2" style="color: var(--brand-accent);">Mod Labs</p>
        <p class="text-muted-brand small mb-0">
          Console modding and electronic repair — Xbox 360 RGH, Nintendo Switch modchips, and more.
        </p>
      </div>
      <div class="col-md-3">
        <p class="text-uppercase small text-muted-brand fw-semibold mb-2">Explore</p>
        <ul class="list-unstyled small mb-0">
          <li><a class="footer-link" href="/services">Services &amp; pricing</a></li>
          <li><a class="footer-link" href="/gallery">Gallery</a></li>
          <li><a class="footer-link" href="/about">About</a></li>
        </ul>
      </div>
      <div class="col-md-3">
        <p class="text-uppercase small text-muted-brand fw-semibold mb-2">Legal</p>
        <ul class="list-unstyled small mb-0">
          <li><a class="footer-link" href="/privacy">Privacy</a></li>
          <li><a class="footer-link" href="/terms">Terms</a></li>
        </ul>
      </div>
    </div>
    <p class="text-muted-brand small mt-4 mb-0">&copy; {year} Mod Labs. All rights reserved.</p>
  </div>
</footer>
