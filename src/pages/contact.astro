---
import BaseLayout from "../layouts/BaseLayout.astro";

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const formAction = formspreeId ? `https://formspree.io/f/${formspreeId}` : null;
const thanksUrl = new URL("/contact?sent=1", Astro.url).href;
const sent = Astro.url.searchParams.get("sent") === "1";
---

<BaseLayout
  title="Request a quote | Mod Labs"
  description="Send a quote request message for electronic repair and attach a photo if needed."
>
  <section class="hero-gradient border-bottom border-brand py-5">
    <div class="container" data-aos="fade-up">
      <h1 class="display-5 fw-bold section-title mb-2">Request a quote</h1>
      <p class="text-muted-brand lead mb-0">
        Use this form for electronic repair requests or custom jobs. Add a message and optionally upload a photo.
      </p>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="row g-5">
        <div class="col-lg-7">
          {sent && (
            <div class="alert alert-success mb-4" role="status" data-aos="fade-up">
              Thanks — your message is on its way. If you don’t hear back within a couple business days, check spam or send a short follow-up.
            </div>
          )}

          {!formAction && (
            <div class="alert alert-warning mb-4" role="status" data-aos="fade-up">
              <strong>Form not wired yet.</strong> Add <code>PUBLIC_FORMSPREE_ID</code> to your <code>.env</code> (see <code>.env.example</code>) and restart the dev server so submissions reach your inbox.
            </div>
          )}

          {formAction && (
            <form
              action={formAction}
              method="POST"
              enctype="multipart/form-data"
              class="needs-validation"
              novalidate
              data-aos="fade-up"
            >
              <input type="hidden" name="_subject" value="Mod Labs — quote / repair request" />
              <input type="hidden" name="_next" value={thanksUrl} />

              <div class="mb-3" aria-hidden="true" style="position: absolute; left: -9999px; height: 0; overflow: hidden;">
                <label for="website">Leave this field empty</label>
                <input id="website" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>

              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label" for="name">Name</label>
                  <input class="form-control" id="name" name="name" type="text" autocomplete="name" required minlength="2" />
                  <div class="invalid-feedback">Please enter your name.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="email">Email</label>
                  <input
                    class="form-control"
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    required
                  />
                  <div class="invalid-feedback">Please enter a valid email.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="phone">Phone <span class="text-muted-brand">(optional)</span></label>
                  <input class="form-control" id="phone" name="phone" type="tel" autocomplete="tel" />
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="requestType">Request type</label>
                  <select class="form-select" id="requestType" name="request_type" required>
                    <option value="" selected disabled>Choose one</option>
                    <option>Electronic repair request</option>
                    <option>General quote request</option>
                    <option>Custom electronics/modding question</option>
                  </select>
                  <div class="invalid-feedback">Please select a request type.</div>
                </div>
                <div class="col-12">
                  <label class="form-label" for="details">Message</label>
                  <textarea
                    class="form-control"
                    id="details"
                    name="message"
                    rows="6"
                    required
                    minlength="20"
                    placeholder="Tell us what is happening with the device and what you want fixed or quoted."
                  ></textarea>
                  <div class="invalid-feedback">Please add a message (at least 20 characters).</div>
                </div>
                <div class="col-12">
                  <label class="form-label" for="photo">Attach a photo <span class="text-muted-brand">(optional)</span></label>
                  <input class="form-control" id="photo" name="attachment" type="file" accept="image/*" />
                  <div class="form-text text-muted-brand">Supported formats depend on your form provider plan/settings.</div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="consent" name="consent" value="yes" required />
                    <label class="form-check-label text-muted-brand" for="consent">
                      I agree you may contact me about this request. See the <a href="/privacy" class="link-light">privacy</a> page for how info is used.
                    </label>
                    <div class="invalid-feedback">Please confirm before sending.</div>
                  </div>
                </div>
              </div>

              <button type="submit" class="btn btn-accent btn-lg mt-4">Send quote request</button>
            </form>
          )}
        </div>

        <div class="col-lg-5" data-aos="fade-up" data-aos-delay="80">
          <div class="p-4 rounded-4 bg-brand-surface border border-brand h-100">
            <h2 class="h5 fw-bold mb-3">Best way to get a useful quote</h2>
            <ul class="text-muted-brand small ps-3 mb-4">
              <li class="mb-2">Describe symptoms and what happened right before the issue started.</li>
              <li class="mb-2">Include device model or revision when possible.</li>
              <li>Attach a clear close-up photo if there is visible damage.</li>
            </ul>
            <div class="d-grid gap-2">
              <a class="btn btn-outline-accent w-100" href="/book">Need a specific mod service instead? Book here</a>
              <p class="text-center small mb-0 mt-1">
                <span class="neon-or-badge">OR</span>
              </p>
              <a class="btn btn-accent w-100" href="/services">More info on services here!</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {formAction && (
    <script>
      const forms = document.querySelectorAll(".needs-validation");
      Array.from(forms).forEach((form) => {
        form.addEventListener(
          "submit",
          (event) => {
            const el = form as HTMLFormElement;
            if (!el.checkValidity()) {
              event.preventDefault();
              event.stopPropagation();
            }
            el.classList.add("was-validated");
          },
          false,
        );
      });
    </script>
  )}
</BaseLayout>
