---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getGalleryProjectCopy } from "../data/galleryProjects";

type Slide = { index: number; url: string; kind: "image" | "video" };

const modules = import.meta.glob<{ default: string }>(
  "../../imgs/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP,mp4,MP4,mov,MOV}",
  { eager: true, import: "default", query: "?url" },
);

const fileRe = /project(\d+)\.(\d+)\.([^.]+)$/i;

function parseProjectFile(
  path: string,
  url: string,
): { projectId: number; slideIndex: number; kind: "image" | "video" } | null {
  const base = path.replaceAll("\\", "/").split("/").pop() ?? path;
  const m = base.match(fileRe);
  if (!m) return null;
  const projectId = Number(m[1]);
  const slideIndex = Number(m[2]);
  const ext = m[3].toLowerCase();
  if (!Number.isFinite(projectId) || !Number.isFinite(slideIndex)) return null;
  const kind = ext === "mp4" || ext === "mov" ? "video" : "image";
  return { projectId, slideIndex, kind };
}

const byProject = new Map<number, Slide[]>();

for (const [path, mod] of Object.entries(modules)) {
  const url = typeof mod === "string" ? mod : mod.default;
  const parsed = parseProjectFile(path, url);
  if (!parsed) continue;
  const list = byProject.get(parsed.projectId) ?? [];
  list.push({ index: parsed.slideIndex, url, kind: parsed.kind });
  byProject.set(parsed.projectId, list);
}

for (const [, slides] of byProject) {
  slides.sort((a, b) => a.index - b.index);
}

const projectIds = [...byProject.keys()].sort((a, b) => a - b);
---

<BaseLayout
  title="Gallery | Mod Labs"
  description="Photo and video gallery of completed Xbox 360 RGH, Nintendo Switch modchip work, and bench shots from Mod Labs."
>
  <section class="hero-gradient border-bottom border-brand py-5">
    <div class="container" data-aos="fade-up">
      <h1 class="display-5 fw-bold section-title mb-2">Gallery</h1>
      <p class="text-muted-brand lead mb-0">
        Take a look at some of my work! I have done plenty of other tasks and jobs but you may find these more interesting.
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      {projectIds.length === 0 ? (
        <p class="text-muted-brand" data-aos="fade-up">
          No gallery files found. Add images or short clips under <code class="text-light">imgs/</code> using names like <code class="text-light">project1.1.jpg</code>, <code class="text-light">project4.1.mp4</code>, then rebuild.
        </p>
      ) : (
        <div class="row g-4">
          {projectIds.map((projectId, rowIdx) => {
            const slides = byProject.get(projectId) ?? [];
            const copy = getGalleryProjectCopy(projectId);
            const carouselId = `gallery-carousel-${projectId}`;
            return (
              <div class="col-12 col-lg-6" data-aos="fade-up" data-aos-delay={Math.min(rowIdx * 40, 200)}>
                <div class="gallery-carousel-module p-2 p-md-3 bg-brand-surface border border-brand">
                  <p class="h6 fw-bold text-light mb-2">{copy.title}</p>
                  <div id={carouselId} class="carousel slide gallery-carousel" data-bs-ride="false" data-bs-interval="false">
                    {slides.length > 1 && (
                      <div class="carousel-indicators">
                        {slides.map((_, i) => (
                          <button
                            type="button"
                            data-bs-target={`#${carouselId}`}
                            data-bs-slide-to={String(i)}
                            class:list={[{ active: i === 0 }]}
                            aria-current={i === 0 ? "true" : undefined}
                            aria-label={`Slide ${i + 1}`}
                          />
                        ))}
                      </div>
                    )}
                    <div class="carousel-inner rounded-3 overflow-hidden border border-brand">
                      {slides.map((slide, i) => (
                        <div class:list={["carousel-item", { active: i === 0 }]}>
                          {slide.kind === "video" ? (
                            <video
                              class="gallery-carousel-media d-block w-100"
                              controls
                              playsinline
                              muted
                              preload="metadata"
                              aria-label={`${copy.title} clip ${slide.index}`}
                            >
                              <source src={slide.url} />
                            </video>
                          ) : (
                            <img
                              class="gallery-carousel-media d-block w-100"
                              src={slide.url}
                              alt={`${copy.title} — photo ${slide.index}`}
                              loading={i === 0 ? "eager" : "lazy"}
                              decoding="async"
                            />
                          )}
                        </div>
                      ))}
                    </div>
                    {slides.length > 1 && (
                      <>
                        <button
                          class="carousel-control-prev"
                          type="button"
                          data-bs-target={`#${carouselId}`}
                          data-bs-slide="prev"
                        >
                          <span class="carousel-control-prev-icon" aria-hidden="true" />
                          <span class="visually-hidden">Previous</span>
                        </button>
                        <button
                          class="carousel-control-next"
                          type="button"
                          data-bs-target={`#${carouselId}`}
                          data-bs-slide="next"
                        >
                          <span class="carousel-control-next-icon" aria-hidden="true" />
                          <span class="visually-hidden">Next</span>
                        </button>
                      </>
                    )}
                  </div>
                  {copy.caption.trim() !== "" && (
                    <p class="gallery-project-caption text-muted-brand small mt-3 mb-0">{copy.caption}</p>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <script>
    document.querySelectorAll(".carousel").forEach((carousel) => {
      carousel.addEventListener("slide.bs.carousel", () => {
        carousel.querySelectorAll("video").forEach((v) => {
          v.pause();
        });
      });
      carousel.addEventListener("slid.bs.carousel", () => {
        carousel.querySelectorAll(".carousel-item:not(.active) video").forEach((v) => {
          v.pause();
        });
      });
    });
  </script>
</BaseLayout>
